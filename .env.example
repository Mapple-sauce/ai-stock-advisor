# ─── AI 模型配置 (DeepSeek / OpenAI 兼容) ───
OPENAI_API_KEY=sk-your-deepseek-api-key
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=deepseek-chat

# ─── 通知渠道 ───
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# ─── 股票池 ───
STOCK_LIST=510300,159915,588000,300308,600519,300750,002594,600036,600276,300760,002371

# ─── 运行模式 ───
# buy | sell | scan | low | mom | hunt | all
RUN_MODE=all

# ─── 报告配置 ───
REPORT_LANGUAGE=zh

# ─── 扫描参数 ───
SCAN_TOP_N=10
